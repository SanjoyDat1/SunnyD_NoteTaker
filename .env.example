# Optional sync backend (see README → Cross-device sync)
# Client — when set, notes load/save via GET/PUT /api/notes (localStorage remains the live cache).
# VITE_API_BASE_URL=http://localhost:3001

# Legacy auth (v1): shared secret — must match SUNNYD_API_SECRET on the server when auth is enabled.
# VITE_SUNNYD_API_SECRET=

# Per-user auth (v2): set SUNNYD_JWT_SECRET on the server (≥32 chars). Client uses register/login;
# no VITE_SUNNYD_API_SECRET needed in jwt mode.

# Server — read by `npm run server` from this file (see server/env.js)
# PORT=3001
# SUNNYD_BIND=127.0.0.1
# Set to 1 ONLY behind a trusted reverse proxy — rate limiting then keys on X-Forwarded-For
# SUNNYD_TRUST_PROXY=0
# SUNNYD_CORS_ORIGIN=http://localhost:5173
# SUNNYD_DB_PATH=server/data/sunnyd.db

# v2 multi-tenant auth (see ADR-009) — enables register/login + JWT per user
# SUNNYD_JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars
# SUNNYD_JWT_EXPIRES_SEC=604800

# Optional PostgreSQL instead of SQLite (hosted deployments)
# DATABASE_URL=postgres://user:pass@localhost:5432/sunnyd

# Legacy single-workspace auth (only when SUNNYD_JWT_SECRET is unset)
# SUNNYD_API_SECRET=

# Google OAuth (see README → Google Workspace)
# Client ID (required for Connect Google). Prefer OAuth type "Single Page Application"
# (PKCE only — no secret). If you use type "Web application", add the secret line below.
VITE_GOOGLE_CLIENT_ID=
# Only if OAuth client type is "Web application" (local/dev). Never commit; never ship in a public build.
# VITE_GOOGLE_CLIENT_SECRET=
